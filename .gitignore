# ============================================================
# MARRA V1 — .gitignore
# ============================================================

# Environment & Secrets (NEVER commit)
.env
.env.*
*.env.local

# Local Storage & Vector Database
qdrant_data/
qdrant_storage/

# Runtime Data Caches & States
data/*
!data/.gitkeep
!data/sample.txt

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
*.tmp

# --- Virtual Environments ---
venv/
env/
.venv/

# --- IDE & Editor ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Testing & Coverage ---
.pytest_cache/
.coverage
htmlcov/
*.xml

# --- Docker ---
# Compose override files for local dev
docker-compose.override.yml

# --- Project Internal Docs ---
project-rules.md
project-blueprint.md
project-blueprint.MD

# --- Local Temp Files ---
dummy.pdf
req_local*.txt
*.pkl
