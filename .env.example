# ============================================================
# MARRA V2 — Environment Configuration Template
# ============================================================
# Local Setup Instructions:
# 1. Copy this file to .env: `cp .env.example .env`
# 2. Fill in the required API keys for local runtime operation.
#
# NOTE: This file tracks local-only operations. Do not include
# production authentication layers or network barriers here.
# ============================================================

# --- Google Gemini Cloud API (Required) ---
# Used strictly for embedding generation (gemini-embedding-2) and 
# multimodal response synthesis (gemini-3.5-flash).
GEMINI_API_KEY=your_gemini_api_key_here

# --- Docker & Internal Service Ports (Optional overrides) ---
API_PORT=8000
UI_PORT=8501
QDRANT_PORT=6333
PHOENIX_PORT=6006
